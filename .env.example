# MANOK Bot 2026 - Discord test setup
# Palitan mo lang itong 4 lines para ma-test agad sa server mo.

DISCORD_TOKEN=PASTE_BOT_TOKEN_HERE
DISCORD_CLIENT_ID=PASTE_APPLICATION_CLIENT_ID_HERE
DISCORD_GUILD_ID=PASTE_TEST_SERVER_ID_HERE
OWNER_IDS=PASTE_YOUR_DISCORD_USER_ID_HERE

# Local defaults. No need palitan kung local test lang.
# Run: npm run dev:infra
# MongoDB: mongodb://localhost:27017/manok
# Redis: redis://localhost:6379
# Lavalink: localhost:2333 password youshallnotpass

# Optional production overrides:
# MONGODB_URI=mongodb://localhost:27017/manok
# REDIS_URL=redis://localhost:6379
# LAVALINK_HOST=localhost
# LAVALINK_PORT=2333
# LAVALINK_PASSWORD=youshallnotpass
# LAVALINK_SECURE=false

# Public dashboard is to be updated soon.
# NEXT_PUBLIC_APP_URL=
# DASHBOARD_URL=

# Optional security/logging:
# ENCRYPTION_MASTER_KEY=replace_with_64_random_hex_chars
# STAFF_LOG_WEBHOOK_URL=
